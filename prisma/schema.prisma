generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OrderStatus {
  NEW
  CONFIRMED
  AWAITING_PAYMENT
  PROCESSING
  SHIPPED
  CANCELLED
}

enum ImportItemStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  nameEn      String
  nameZh      String
  descriptionEn String?
  descriptionZh String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id              String           @id @default(cuid())
  slug            String           @unique
  status          ProductStatus    @default(DRAFT)
  categoryId      String
  nameEn          String
  nameZh          String
  subtitleEn      String?
  subtitleZh      String?
  descriptionEn   String?
  descriptionZh   String?
  storyEn         String?
  storyZh         String?
  price           Decimal          @db.Decimal(10, 2)
  compareAtPrice  Decimal?         @db.Decimal(10, 2)
  featured        Boolean          @default(false)
  isNew           Boolean          @default(false)
  leadTimeEn      String?
  leadTimeZh      String?
  shippingNoteEn  String?
  shippingNoteZh  String?
  attributes      Json?
  sourcePayload   Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  category        Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images          ProductImage[]
  variants        ProductVariant[]
  orderItems      OrderItem[]
  tags            ProductTag[]
}

model ProductImage {
  id         String   @id @default(cuid())
  productId  String
  url        String
  altEn      String?
  altZh      String?
  sortOrder  Int      @default(0)
  isCover    Boolean  @default(false)
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id          String    @id @default(cuid())
  productId   String
  sku         String?   @unique
  labelEn     String
  labelZh     String
  price       Decimal?  @db.Decimal(10, 2)
  inventory   Int?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
}

model Tag {
  id        String       @id @default(cuid())
  slug      String       @unique
  labelEn   String
  labelZh   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  products  ProductTag[]
}

model ProductTag {
  productId String
  tagId     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

model Address {
  id         String   @id @default(cuid())
  fullName   String
  email      String
  phone      String
  country    String
  region     String?
  city       String
  address1   String
  address2   String?
  postalCode String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]
}

model Order {
  id             String       @id @default(cuid())
  orderNumber    String       @unique
  status         OrderStatus  @default(NEW)
  email          String
  note           String?
  currency       String       @default("USD")
  subtotal       Decimal      @db.Decimal(10, 2)
  shippingAmount Decimal?     @db.Decimal(10, 2)
  totalAmount    Decimal?     @db.Decimal(10, 2)
  addressId      String?
  trackingNumber String?
  carrier        String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  address        Address?     @relation(fields: [addressId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  shipments      Shipment[]
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  productId   String
  variantId   String?
  productName String
  variantName String?
  quantity    Int
  unitPrice   Decimal         @db.Decimal(10, 2)
  createdAt   DateTime        @default(now())
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
}

model Shipment {
  id             String   @id @default(cuid())
  orderId        String
  carrier        String
  trackingNumber String
  statusNote     String?
  shippedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ImportBatch {
  id          String       @id @default(cuid())
  name        String
  source      String?
  status      String       @default("PENDING")
  totalItems  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  items       ImportItem[]
}

model ImportItem {
  id             String           @id @default(cuid())
  importBatchId  String
  sourceId       String?
  status         ImportItemStatus @default(PENDING_REVIEW)
  rawPayload     Json
  normalizedData Json?
  reviewNotes    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  importBatch    ImportBatch      @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
}

model ContentPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleEn     String
  titleZh     String
  bodyEn      String?
  bodyZh      String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSetting {
  id         String   @id @default(cuid())
  key        String   @unique
  value      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Admin {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  displayName   String?
  role          String   @default("admin")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
